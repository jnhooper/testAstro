---
/**
 * make sure to shout out this guy
 * https://github.com/web-tiki/responsive-grid-of-hexagons/tree/css-grid
 */

 interface BaseProps {
 href?: string
 backgroundColor?: string
 }
 interface WithImage extends BaseProps{
 imgSrc: string
 imgAlt: string
 }

 interface WithoutImage extends BaseProps{
 imgSrc?: never
 imgAlt?: never
 }

 type Props = WithImage | WithoutImage;
 
 const {
   imgSrc,
   imgAlt="",
   href,
   backgroundColor,
   isOutlined = false,
  } = Astro.props;

  const outlineColor  = isOutlined ? 'var(--root-popOne)': 'transparent' ;
  const outlineSize = isOutlined ? '4px' : '1px';

---
<li class="hex">
  <div class="hexIn">
    {href ?
      (
      <a class="hexLink" href={href}>
        <img src={imgSrc} alt={imgAlt} />
        <div class="slotWrapper">
          <slot/>
        </div>
      </a>
      ) : (
        <div class="hexLink">
          <img src={imgSrc} alt={imgAlt} />
          <div class="slotWrapper">
            <slot/>
          </div>
        </div>
      )
      }
    { isOutlined ? (
      <div class:list={["outline","top"]}/>
      <div class:list={["outline","bot"]}/>
    ) : null}
  </div>
</li>

<style
  define:vars={{
    backgroundColor,
    outlineColor,
    outlineSize
  }}
  lang="scss"
>
  .slotWrapper{
    width:100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hex {
    grid-column-end: span 2;
    position: relative;
    visibility:hidden;
    overflow-x: clip;
    outline:1px solid transparent; /* fix for jagged edges in FF on hover transition */
    :global(*){
      --hexBorderColor: var(--outlineColor)
    }
  }
  .hex::after{
    content:'';
    display:block;
    padding-bottom: 86.602%;  /* =  100 / tan(60) * 1.5 */
  }
  .hexIn{
    .outline {
      position:absolute;
      top:0;
      right:0;
      width: 100%;
      pointer-events:none;
      height:100%;
      outline: none;
      &:before, &:after{
        content:"";
        position: absolute;
        background-color: var(--outlineColor);
        transition: var(--root-transition);
      }
      &:after{
        height:50%;
        width:var(--outlineSize);
      }
      &:before{
        width:50%;
        height:var(--outlineSize);
      }
      &.top{
      /* top left */
        &:before{
          top:1;
          right:0;
        }
         /* top right */
        &:after{
          top:var(--outlineSize);
          right:0;
        }
      }
      &.bot{
      /* bot right */
        &:before{
          bottom:0;
          left:0;
        }
        /* bot left */
        &:after{
          left:calc(0 - var(--outlineSize));
          bottom:var(--outlineSize);
        }
      }
    }
    position: absolute;
    width: 100%;
  /* [> =  width / sin(60) <] */
    padding-bottom: 115.470%; 
    overflow: hidden;
    visibility: hidden;
    transform: rotate3d(0,0,1,-60deg) skewY(30deg);
  }
  .hexIn > * {
    position: absolute;
    visibility: visible;
  }
  .hexLink {
    display:flex;
    width: 100%;
    height: 100%;
    text-align: center;
    color: #fff;
    overflow: hidden;
    transform: skewY(-30deg) rotate3d(0,0,1,60deg);
    background-color: var(--backgroundColor);
    border-left: var(--outlineSize) solid var(--outlineColor); 
    border-right: var(--outlineSize) solid var(--outlineColor); 
    transition: var(--root-transition);
  }
  /*** HEX CONTENT **********************************************************************/
.hex img {
  position: absolute;
  left: -100%;
  right: -100%;
  margin: 0 auto;
  transform: rotate3d(0,0,0,0deg);
}
  
</style>
