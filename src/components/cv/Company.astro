---
import type {Company} from '@/data/resume';
import DateRange from './DateRange.astro';
import Role from './Role.astro';

export interface Props {
  company: Company
}

const {company} = Astro.props
const {
companyName,
  startDate,
  endDate,
  roles
} = company;
const marginClass = 'ml-3'
const companyAccentColor = '#37E2D5';
---
<li class:list={[
  marginClass,
  "company"
]}>
  <h2 class="text-3xl">{companyName}</h2>
  <h4>
    <DateRange startDate={startDate} endDate={endDate}/>
  </h4>
  <ul
    class:list={[
    "flex",
    "flex-col",
    "gap-y-3"
    ]}
  >
    {roles.map(role => (
      <Role role={role} liClasses={[marginClass]}/>
    ))}
  </ul> 
</li>

<style
  define:vars={{
    companyAccentColor
  }}
>
  .company{
    position:relative; 
    border-left: 1px solid var(--companyAccentColor);
    position: relative;
    padding-left: 1ch;
    color:  
   }
  
  .company::before{
    content:"";
    position: absolute;
    top: 0;
    height:2px;
    width:1ch;
    left:0;
    display:block;
    background-color: var(--companyAccentColor);
  }
  .company::after{
    content:"";
    position: absolute;
    bottom: 0;
    height:2px;
    width:1ch;
    left:0;
    display:block;
    background-color: var(--companyAccentColor); 
  }
</style>