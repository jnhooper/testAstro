---
import Hexagon from '@/components/Hexagon.astro';

interface Props {
  href: string
  type?: 'tel' | 'email'| 'other'
}
const {
href,
type = 'other',
  } = Astro.props;

  let formattedLink = href;
  switch(type){
    case 'tel':
      formattedLink = `tel:${href}`
      break;
    case 'email':
    formattedLink = `mailto:${href}`
    break;
  }

---
<Hexagon>
  <hex-contact class:list={['wrapper']} data-href={href}>
      <a class:list={['link']} href={formattedLink}>
        <slot/>
      </a>
      <div  class:list={['copy']}>
      <button>        
         copy
      </button>
      </div>
  </hext-contact>
</Hexagon>

<script>
  import ContactHex from './ContactHex.ts';
  customElements.define('hex-contact', ContactHex);
</script>

<style lang="scss">
  .wrapper {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-rows: 1fr 25%;
    --darkBlue:rgba(2,0,36,1);

    .link {
      /*background: rgb(2,0,36);
      background: linear-gradient(180deg, rgba(2,0,36,1) 0%, rgba(9,9,121,1) 56%, rgba(0,212,255,1) 100%); 
       */
      background: radial-gradient(circle at 50% 140%, rgba(0,213,255,1) 25%, rgba(5,5,126,1) 73%, var(--darkBlue) 100%); 
      display: flex;
      height:100%;
      align-items:center;
      justify-content: center;
    }
    .copy {
      --pink: rgb(216,0,255);
      border-top: 4px solid var(--pink);
      background:radial-gradient(farthest-corner at 50% 160%,var(--darkBlue) 55%, #230390  70%,var(--pink) 100%) ; 
      border-radius: 100%;
      margin-top: -15%;
      width: 120%;
      justify-self: center;
      display: flex;
      align-items:center;
      justify-content:center;

      button {
        justify-self: center;
      }
    }
  }
</style>
