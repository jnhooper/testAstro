---
import Layout from '@/layouts/Layout.astro';
import {resume} from '@/data/resume';
import Company from '@/components/cv/Company.astro';

---
<Layout>
  <ul class:list={[
    "flex",
    "flex-col",
    "gap-y-6"
  ]}>
    {resume.map((company) => (
      <Company company={company}/>
    ))}
  </ul>
</Layout>

<style>
  html{
    color:white;
    background-color: black;
  }
</style>